PORT=3000
REDIS_URL=redis://0.0.0.0:6379 #to run this on your local network

# Create an Auth0 account, create a Regular Web Application, and put the keys here
# OIDC_SECRET=your_long_random_secret_string
# BASE_URL=http://localhost:8000
# OIDC_CLIENT_ID=your_auth0_client_id
# OIDC_ISSUER_BASE_URL=https://your_tenant.auth0.com

# 32+ character random string to encrypt the session cookie
#
# We're generating a secret for your convenience, but for production,
# generate your own secret using `openssl rand -hex 32`
SECRET=**************MASKED*******************

BASE_URL=http://localhost:3000
ISSUER_BASE_URL=https://your_tenent.us.auth0.com
CLIENT_ID=00000101010101010010101010 //your client id as number